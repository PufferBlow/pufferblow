# Pufferblow server stack — production .env template.
#
# Copy to `.env` next to docker-compose.prod.server.yml and fill in every
# REQUIRED value (anything with a `change-me-...` placeholder) before
# running `docker compose up`.
#
#   cp .env.server.example .env
#   docker compose --env-file .env -f docker-compose.prod.server.yml up -d --build

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# REQUIRED. Picked up by the postgres service AND used to build the default
# PUFFERBLOW_DATABASE_URI handed to pufferblow-server.
POSTGRES_DB=pufferblow
POSTGRES_USER=pufferblow
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Optional explicit URI. When set, overrides the auto-built one in the
# compose file. Useful if you're pointing at an external Postgres
# (managed RDS, Neon, your own VPS, etc.) instead of the bundled service.
PUFFERBLOW_DATABASE_URI=postgresql+psycopg2://pufferblow:change-me-to-a-long-random-string@postgres:5432/pufferblow

# ─── API bind ───────────────────────────────────────────────────────────────
# Defaults are fine for most reverse-proxy setups (Traefik, nginx, Caddy).
PUFFERBLOW_API_HOST=0.0.0.0
PUFFERBLOW_API_PORT=7575

# ─── SFU bootstrap ──────────────────────────────────────────────────────────
# REQUIRED. Shared secret the media-sfu uses to authenticate its bootstrap
# request to the Pufferblow API. Value is printed by `pufferblow setup
# --setup-media-sfu`; if you ran setup outside the container, copy it here.
RTC_BOOTSTRAP_SECRET=change-this-bootstrap-secret
RTC_BOOTSTRAP_HTTP_TIMEOUT=5s

# ─── TURN (coturn sidecar) ──────────────────────────────────────────────────
# REQUIRED. Long-term credentials coturn advertises and the Pufferblow API
# hands back to clients in its ICE-servers list. Both values must match
# whatever the API config thinks the TURN credentials are.
PUFFERBLOW_TURN_USERNAME=pufferblow
PUFFERBLOW_TURN_PASSWORD=change-me-to-a-long-random-string

# Public realm hostname coturn announces. Set to a DNS name that clients
# on the public internet can resolve. Falls back to pufferblow.space if
# unset.
TURN_REALM=turn.example.com

# ─── RTC media UDP port range ───────────────────────────────────────────────
# The SFU exchanges RTP on these UDP ports. Open them on your host firewall
# / cloud security group. Clients behind strict NAT route through coturn,
# but everyone else uses these directly for the lowest-latency path.
RTC_UDP_PORT_MIN=50000
RTC_UDP_PORT_MAX=50199

# ─── media-sfu build source ─────────────────────────────────────────────────
# Default is the public GitHub repo (network is required at build time).
# For local self-builds, set this to a local checkout path of media-sfu:
#   MEDIA_SFU_GIT_CONTEXT=../media-sfu
MEDIA_SFU_GIT_CONTEXT=https://github.com/pufferblow/media-sfu.git
